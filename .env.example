# ========================================
# Server
# ========================================
APP_PORT=8080
APP_VERSION=1.0.0

# ========================================
# PostgreSQL
# ========================================
# 格式: postgres://[user]:[password]@[host]:[port]/[database][?currentSchema=xxx]
# 示例：
#   无密码，默认 public: postgres://postgres@localhost:5432/location_service
#   有密码: postgres://postgres:mypassword@localhost:5432/location_service
#   指定 schema: postgres://postgres:mypassword@localhost:5432/postgres?currentSchema=mocklocation
#   带 search_path: postgres://postgres:mypassword@localhost:5432/location_service?options=-c%20search_path%3Dmy_schema
DATABASE_URL=postgres://postgres:password@localhost:5432/location_service?currentSchema=mocklocation

# 可选：单独配置 schema（推荐用 DATABASE_URL 的 options 参数）
# PG_SCHEMA=my_schema

# ========================================
# Redis
# ========================================
# 格式: redis://[:password@]host:port/db_number
# 示例：
#   无密码: redis://localhost:6379/0
#   有密码: redis://:mypassword@localhost:6379/0
#   带 ACL 用户名（Redis 6+）: redis://username:mypassword@localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ========================================
# Auth
# ========================================
# Token 加密盐（生产环境务必修改）
TOKEN_SECRET=change-me-in-production
# Token 有效期（天）
TOKEN_EXPIRE_DAYS=30
# Bootstrap 密钥（首次部署时用于把普通用户提升为管理员，用完可删除）
ADMIN_BOOTSTRAP_SECRET=your-bootstrap-secret-here

# ========================================
# Amap (高德地图)
# ========================================
# 在 https://lbs.amap.com/ 申请的服务端 Key
AMAP_KEY=your-amap-server-key

# ========================================
# Rate limit
# ========================================
# 地点搜索每用户每分钟最多 N 次
PLACE_SEARCH_LIMIT_PER_MINUTE=60
# 登录每 IP 每分钟最多 N 次
LOGIN_LIMIT_PER_MINUTE=10
