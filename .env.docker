# Docker Compose 用的环境变量
# 复制为 .env 后修改

# 外部端口
APP_PORT=8080

# PostgreSQL
POSTGRES_PASSWORD=please-change-this-pg-password
POSTGRES_DB=location_service

# Redis
REDIS_PASSWORD=please-change-this-redis-password

# Auth
TOKEN_SECRET=please-change-this-token-secret
TOKEN_EXPIRE_DAYS=30

# Bootstrap（首次部署时用，用完可改）
ADMIN_BOOTSTRAP_SECRET=please-change-this-bootstrap-secret

# Amap
AMAP_KEY=
